# 站点访问密码。填写后，访问部署站点需要先输入此密码。
ACCESS_PASSWORD=""

# BYOK 服务端密钥。生产环境必须配置稳定私钥，除非明确允许临时密钥。
# Docker Compose 本地冒烟测试可以把 BYOK_ALLOW_EPHEMERAL_KEY 设为 true；
# 生产 Docker 和 Cloudflare Workers 应使用固定私钥。
BYOK_PRIVATE_KEY_PEM=""
BYOK_KEY_ID=""
BYOK_ALLOW_EPHEMERAL_KEY="false"

# 部署安全模式。local 允许本地/内网代理端点；hosted 默认阻止这些端点。
# Cloudflare Workers 建议使用 hosted，并只连接公开 HTTPS 上游。
DEPLOYMENT_MODE="local"
ALLOW_LOCAL_NETWORK_PROXY=""
# 仅当你的平台会剥离伪造代理头时，才信任 x-forwarded-* 等代理头。
TRUST_PROXY_HEADERS="false"

# 本地模式可选，托管模式必填共享存储。
# 下列 STORE 支持 memory 或 upstash；托管和多实例部署建议全部使用 upstash。
RATE_LIMIT_STORE="memory"
DOCUMENT_PARSE_JOB_STORE="memory"
PLUGIN_REGISTRY_STORE="memory"
MODEL_PROVIDER_STORE="memory"
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# 上传限制。单位为字节。
MAX_ATTACHMENT_FILE_BYTES="10485760"

# 公开 URL。
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_API_URL=""

# 服务端默认模型供应商。
# DEFAULT_PROVIDER_TYPE 支持 Gemini、Anthropic、OpenAI 或 OpenAI Compatible。
DEFAULT_PROVIDER_TYPE="Gemini"
DEFAULT_PROVIDER_NAME="Default"
DEFAULT_PROVIDER_BASE_URL=""
DEFAULT_PROVIDER_API_KEY=""
DEFAULT_PROVIDER_MODELS=""
# 主聊天模型请求超时，单位毫秒。设为 0 可禁用。
CHAT_PROVIDER_TIMEOUT_MS="120000"
# Grok 联网搜索请求超时，单位毫秒。设为 0 可禁用。
GROK_SEARCH_TIMEOUT_MS="60000"

# 默认任务模型。
DEFAULT_MODEL_TITLE_GENERATION=""
DEFAULT_MODEL_RELATED_QUESTIONS=""
DEFAULT_MODEL_CONTEXT_COMPRESSION=""
DEFAULT_MODEL_PROMPT_OPTIMIZATION=""
DEFAULT_MODEL_RAG_QUERY=""
DEFAULT_MODEL_MEMORY=""

# 默认 RAG/向量库和文档解析配置。
DEFAULT_RAG_BASE_URL=""
DEFAULT_RAG_TOKEN=""
DEFAULT_RAG_TOP_K="10"
DEFAULT_RAG_CHUNK_SIZE="512"
DEFAULT_RAG_NAMESPACE="default"
DEFAULT_DOCUMENT_PARSE_PROVIDER="mineru"
DEFAULT_MINERU_API_TOKEN=""
DEFAULT_LLAMA_PARSE_API_KEY=""

# 默认语音供应商配置。
DEFAULT_VOICE_PROVIDER=""
DEFAULT_ELEVENLABS_API_KEY=""
DEFAULT_ELEVENLABS_STT_MODEL="scribe_v2"
DEFAULT_ELEVENLABS_TTS_MODEL="eleven_flash_v2_5"
DEFAULT_ELEVENLABS_TTS_VOICE_ID="bIHbv24MWmeRgasZH58o"
DEFAULT_MIMO_API_KEY=""
DEFAULT_MIMO_STT_MODEL="mimo-v2.5-asr"
DEFAULT_MIMO_TTS_MODEL="mimo-v2.5-tts"
DEFAULT_MIMO_TTS_VOICE_ID="mimo_default"

# 默认系统行为。
DEFAULT_SYSTEM_PROMPT=""
DEFAULT_ENABLE_AUTO_TITLE="true"
DEFAULT_ENABLE_RELATED_QUESTIONS="true"
DEFAULT_ENABLE_AUTO_COMPRESSION="true"
DEFAULT_COMPRESSION_THRESHOLD="12"
DEFAULT_HISTORY_KEEP_COUNT="4"
DEFAULT_ENABLE_CODE_COLLAPSE="true"
DEFAULT_ENABLE_HTML_VISUAL_PROMPT="true"
